; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="hexasphere"
run/main_scene="res://addons/hexasphere_generator/example.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://addons/hexasphere_generator/icon.svg"

[dotnet]

project/assembly_name="hexasphere"

[editor_plugins]

enabled=PackedStringArray("res://addons/hexasphere_generator/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
environment/defaults/default_clear_color=Color(0.039215688, 0.043137256, 0.0627451, 1)
